# =========================
# Sistema Operativo
# =========================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini

# =========================
# Backend (Rust / Cargo)
# =========================
# Cartelle di compilazione
/target/
crates/*/target/

# File di backup generati da rustfmt
**/*.rs.bk

# =========================
# Frontend (Node.js / Next.js)
# =========================
# Dipendenze
frontend/node_modules/
node_modules/

# Cartelle di build e cache di Next.js
frontend/.next/
frontend/out/
frontend/build/

# Log di NPM / Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Artefatti WebAssembly (WASM)
# =========================
# I moduli wasm vengono compilati tramite `npm run wasm:build`, 
# quindi non serve tracciarli su git.
frontend/src/wasm/

# =========================
# Database
# =========================
# Ignoriamo i file del database SQLite locale per evitare di 
# caricare dati di test sul repository.
*.db
*.db-journal
*.sqlite
*.sqlite3
auction.db

# =========================
# Variabili d'Ambiente
# =========================
# Non committare MAI le chiavi segrete
#.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# IDE e Strumenti di Sviluppo
# =========================
.vscode/
.idea/
*.swp
*.swo